# ─────────────────────────────────────────────────────────
# MARK'S SAFETY SYSTEM — Environment Variables
# Copy these into Railway's "Variables" tab (never share this file)
# ─────────────────────────────────────────────────────────

# Twilio (get these from twilio.com → Console Dashboard)
TWILIO_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH=your_auth_token_here
TWILIO_FROM=+1XXXXXXXXXX        # Your Twilio phone number

# Phone numbers (include country code, e.g. +15551234567)
MY_PHONE=+1XXXXXXXXXX           # Mark's cell phone
EMERGENCY_PHONE=+1XXXXXXXXXX    # Emergency contact's phone

# Email addresses
MY_EMAIL=mark@example.com
EMERGENCY_EMAIL=contact@example.com

# Gmail credentials for sending emails
# Use a Gmail App Password (not your regular password)
# Instructions: myaccount.google.com → Security → App Passwords
EMAIL_USER=yourgmail@gmail.com
EMAIL_PASS=xxxx xxxx xxxx xxxx  # 16-character app password

# App settings
CHECKIN_HOUR=10                 # Hour of daily ping (24hr, your local time)
TIMEZONE=America/Chicago        # Your timezone (change if needed)
CHECKIN_TOKEN=AngelAndScout2024 # Secret word in your check-in link (you choose)
APP_URL=https://your-app.railway.app  # Fill in after Railway gives you a URL
SECRET_KEY=some-random-string-here
